# Server port
PORT=4021

# Hedera Network
HEDERA_NETWORK=hedera:testnet

# Account to receive payments - should be different from your client
PAY_TO_ACCOUNT=0.0.YOUR_ACCOUNT_ID

# x402 Facilitator URL
FACILITATOR_URL=https://api.testnet.blocky402.com

# Mirror Node URL (optional - defaults based on network)
# MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# Client credentials (for testing payment flow)
# HEDERA_CLIENT_ID=0.0.YOUR_CLIENT_ID
# HEDERA_CLIENT_KEY=your_ecdsa_private_key
