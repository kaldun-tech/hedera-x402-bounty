{
  "name": "hedera-x402-bounty",
  "version": "0.1.0",
  "description": "Pay-per-query Hedera Mirror Node metrics API with x402 micropayments",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test:client": "tsx scripts/test-client.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@x402/core": "^2.16.0",
    "@x402/hedera": "^2.16.0",
    "@x402/hono": "^2.16.0",
    "dotenv": "^16.4.7",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
